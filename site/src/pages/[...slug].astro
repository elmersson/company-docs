---
import DocsLayout from "../layouts/DocsLayout.astro"
import ServiceNav from "../components/ServiceNav.astro"
import BreakingBadge from "../components/BreakingBadge.astro"
import { getAllDocPaths, loadServiceNav, loadConsumers } from "../utils/docs-loader"

export async function getStaticPaths() {
  const paths = await getAllDocPaths()

  return paths.map(doc => ({
    params: { slug: doc.slug },
    props: { doc },
  }))
}

const { doc } = Astro.props
const nav = await loadServiceNav(doc.service, doc.slug)
const consumers = await loadConsumers(doc.slug)
---

<DocsLayout title={`${doc.entity} - ${doc.service}`}>
  <div class="doc-page">
    <aside class="doc-sidebar">
      <ServiceNav items={nav} current={doc.slug} />
    </aside>

    <article class="doc-content">
      <header>
        <div class="doc-breadcrumb">
          <a href="/">Home</a> /
          <a href={`/${doc.service}/${doc.docType}`}>{doc.service}</a> /
          <span>{doc.docType}</span>
        </div>

        <h1>
          {doc.entity}
          {doc.hasBreakingChanges && <BreakingBadge />}
        </h1>

        <div class="doc-meta">
          {doc.sourcePrUrl && (
            <span>
              Source: <a href={doc.sourcePrUrl}>{doc.sourceRepo} PR #{doc.sourcePr}</a>
            </span>
          )}
          {doc.generatedAt && (
            <span>Updated: {new Date(doc.generatedAt).toLocaleDateString()}</span>
          )}
        </div>
      </header>

      {consumers.length > 0 && (
        <div class="consumed-by">
          <h4 class="consumed-by-title">Consumed by</h4>
          <ul class="consumed-by-list">
            {consumers.map(consumer => (
              <li>
                <a href={`/${consumer.slug}`}>{consumer.service}</a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="doc-body" set:html={doc.html} />
    </article>
  </div>
</DocsLayout>
