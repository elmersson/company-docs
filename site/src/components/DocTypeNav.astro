---
interface Props {
  service: string
  current: string
  availableDocTypes: string[]
}

const { service, current, availableDocTypes } = Astro.props

const tabs = [
  { label: "API Endpoints", docType: "api" },
  { label: "API Calls", docType: "api-calls" },
  { label: "Models", docType: "models" },
  { label: "Events", docType: "events" },
  { label: "Flows", docType: "flows" },
].filter(tab => availableDocTypes.includes(tab.docType))
---

<nav class="doc-type-nav">
  {tabs.map(tab => (
    <a
      href={`/${service}/${tab.docType}`}
      class:list={["doc-type-tab", { active: current === tab.docType }]}
    >
      {tab.label}
    </a>
  ))}
</nav>
