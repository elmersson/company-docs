---
interface Props {
  name: string
  type: string
  apiCount: number
  apiCallCount: number
  modelCount: number
  eventCount: number
  flowCount: number
  hasBreakingChanges: boolean
}

const { name, type, apiCount, apiCallCount, modelCount, eventCount, flowCount, hasBreakingChanges } = Astro.props
const totalDocs = apiCount + apiCallCount + modelCount + eventCount + flowCount

// Link to the first doc type that has content
const DOC_TYPE_ORDER = ["api", "api-calls", "models", "events", "flows"] as const
const counts: Record<string, number> = { api: apiCount, "api-calls": apiCallCount, models: modelCount, events: eventCount, flows: flowCount }
const firstDocType = DOC_TYPE_ORDER.find(dt => counts[dt] > 0) || "api"
const href = `/${name}/${firstDocType}`
---

<a href={href} class="service-card">
  <div class="card-header">
    <h3>{name}</h3>
    <span class="card-type">{type}</span>
    {hasBreakingChanges && <span class="badge-breaking">BREAKING</span>}
  </div>
  <div class="card-stats">
    {apiCount > 0 && <span class="stat">{apiCount} Endpoint{apiCount !== 1 ? "s" : ""}</span>}
    {apiCallCount > 0 && <span class="stat">{apiCallCount} API Call{apiCallCount !== 1 ? "s" : ""}</span>}
    {modelCount > 0 && <span class="stat">{modelCount} Model{modelCount !== 1 ? "s" : ""}</span>}
    {eventCount > 0 && <span class="stat">{eventCount} Event{eventCount !== 1 ? "s" : ""}</span>}
    {flowCount > 0 && <span class="stat">{flowCount} Flow{flowCount !== 1 ? "s" : ""}</span>}
    {totalDocs === 0 && <span class="stat muted">No docs yet</span>}
  </div>
</a>
