generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LoanApplication {
  id                String   @id @default(uuid())
  amount            Float
  employmentStatus  String
  applicantName     String
  email             String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  userId    String
  details   String?
  createdAt DateTime @default(now())
}
